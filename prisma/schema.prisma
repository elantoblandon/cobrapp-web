generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  COLLECTOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum CreditRating {
  NEW
  GOOD
  WATCH
  RISKY
  BAD
}

enum PaymentFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum LoanStatus {
  DRAFT
  ACTIVE
  PAID
  OVERDUE
  DEFAULTED
  CANCELLED
}

enum InstallmentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
  OTHER
}

enum CashSessionStatus {
  OPEN
  CLOSED
  REVIEWED
}

enum SyncOperationType {
  PAYMENT_CREATED
  EXPENSE_CREATED
  CLIENT_NOTE_CREATED
}

enum SyncOperationStatus {
  PENDING
  SYNCED
  FAILED
  CONFLICT
}

model User {
  id                String            @id @default(cuid())
  name              String
  email             String            @unique
  passwordHash      String?
  role              UserRole
  status            UserStatus        @default(ACTIVE)
  phone             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  assignedRoutes    RouteAssignment[]
  createdLoans      Loan[]            @relation("LoanCreator")
  collectedPayments Payment[]
  cashSessions      CashSession[]
  expenses          Expense[]
  syncOperations    SyncOperation[]
}

model Client {
  id              String        @id @default(cuid())
  fullName        String
  identityNumber  String?
  phone           String?
  address         String?
  businessName    String?
  businessAddress String?
  status          ClientStatus  @default(ACTIVE)
  creditRating    CreditRating  @default(NEW)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  routeClients    RouteClient[]
  loans           Loan[]
  payments        Payment[]

  @@index([fullName])
  @@index([identityNumber])
}

model Route {
  id          String            @id @default(cuid())
  name        String
  description String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  assignments RouteAssignment[]
  clients     RouteClient[]
}

model RouteAssignment {
  id          String    @id @default(cuid())
  routeId     String
  collectorId String
  startsAt    DateTime  @default(now())
  endsAt      DateTime?
  route       Route     @relation(fields: [routeId], references: [id])
  collector   User      @relation(fields: [collectorId], references: [id])

  @@unique([routeId, collectorId, startsAt])
  @@index([collectorId])
}

model RouteClient {
  id        String    @id @default(cuid())
  routeId   String
  clientId  String
  sortOrder Int       @default(0)
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  route     Route     @relation(fields: [routeId], references: [id])
  client    Client    @relation(fields: [clientId], references: [id])

  @@unique([routeId, clientId, startsAt])
  @@index([clientId])
}

model Loan {
  id                String           @id @default(cuid())
  clientId          String
  createdById       String
  principalAmount   Decimal          @db.Decimal(12, 2)
  interestAmount    Decimal          @db.Decimal(12, 2)
  totalAmount       Decimal          @db.Decimal(12, 2)
  installmentAmount Decimal          @db.Decimal(12, 2)
  frequency         PaymentFrequency
  termInstallments  Int
  startDate         DateTime
  firstDueDate      DateTime
  expectedEndDate   DateTime
  status            LoanStatus       @default(ACTIVE)
  automaticLateFee  Boolean          @default(false)
  lateFeeAmount     Decimal?         @db.Decimal(12, 2)
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  client            Client           @relation(fields: [clientId], references: [id])
  createdBy         User             @relation("LoanCreator", fields: [createdById], references: [id])
  installments      Installment[]
  payments          Payment[]

  @@index([clientId, status])
  @@index([status])
}

model Installment {
  id         String            @id @default(cuid())
  loanId     String
  number     Int
  dueDate    DateTime
  amountDue  Decimal           @db.Decimal(12, 2)
  amountPaid Decimal           @default(0) @db.Decimal(12, 2)
  status     InstallmentStatus @default(PENDING)
  paidAt     DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  loan       Loan              @relation(fields: [loanId], references: [id])
  payments   Payment[]

  @@unique([loanId, number])
  @@index([dueDate, status])
}

model Payment {
  id            String        @id @default(cuid())
  loanId        String
  installmentId String?
  clientId      String
  collectorId   String
  cashSessionId String?
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod @default(CASH)
  paidAt        DateTime      @default(now())
  notes         String?
  offlineKey    String?       @unique
  syncedAt      DateTime?
  createdAt     DateTime      @default(now())
  loan          Loan          @relation(fields: [loanId], references: [id])
  installment   Installment?  @relation(fields: [installmentId], references: [id])
  client        Client        @relation(fields: [clientId], references: [id])
  collector     User          @relation(fields: [collectorId], references: [id])
  cashSession   CashSession?  @relation(fields: [cashSessionId], references: [id])

  @@index([collectorId, paidAt])
  @@index([clientId])
  @@index([loanId])
}

model CashSession {
  id             String            @id @default(cuid())
  collectorId    String
  openedById     String?
  sessionDate    DateTime
  openingAmount  Decimal           @default(0) @db.Decimal(12, 2)
  expectedAmount Decimal           @default(0) @db.Decimal(12, 2)
  countedAmount  Decimal?          @db.Decimal(12, 2)
  difference     Decimal?          @db.Decimal(12, 2)
  status         CashSessionStatus @default(OPEN)
  openedAt       DateTime          @default(now())
  closedAt       DateTime?
  notes          String?
  collector      User              @relation(fields: [collectorId], references: [id])
  payments       Payment[]
  expenses       Expense[]

  @@unique([collectorId, sessionDate])
  @@index([sessionDate, status])
}

model Expense {
  id            String       @id @default(cuid())
  collectorId   String
  cashSessionId String?
  amount        Decimal      @db.Decimal(12, 2)
  category      String
  description   String?
  spentAt       DateTime     @default(now())
  offlineKey    String?      @unique
  syncedAt      DateTime?
  collector     User         @relation(fields: [collectorId], references: [id])
  cashSession   CashSession? @relation(fields: [cashSessionId], references: [id])

  @@index([collectorId, spentAt])
}

model SyncOperation {
  id            String              @id @default(cuid())
  deviceId      String
  userId        String
  operationType SyncOperationType
  status        SyncOperationStatus @default(PENDING)
  payload       Json
  errorMessage  String?
  createdAt     DateTime            @default(now())
  syncedAt      DateTime?
  user          User                @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([deviceId, createdAt])
}
